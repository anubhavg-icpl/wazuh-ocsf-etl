    {
      "id": 25,
      "type": "table",
      "title": "Recent Alerts — Rule ID / Description / Level / Groups / Decoder / MITRE / User / IP",
      "description": "All key Wazuh rule fields. Use column filters to hunt. finding_uid = Rule ID. finding_types = rule groups (JSON). decoder_name = parsing decoder.",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "gridPos": { "x": 0, "y": 50, "w": 24, "h": 12 },
      "options": {
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [{ "displayName": "Time", "desc": true }]
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "filterable": true, "inspect": true }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Time"         }, "properties": [{ "id": "unit", "value": "dateTimeFromNow" }, { "id": "custom.width", "value": 130 }] },
          { "matcher": { "id": "byName", "options": "Rule ID"      }, "properties": [{ "id": "custom.width", "value": 80  }] },
          { "matcher": { "id": "byName", "options": "Level"        }, "properties": [{ "id": "custom.width", "value": 55  }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 7 }, { "color": "orange", "value": 10 }, { "color": "dark-red", "value": 13 }] } }, { "id": "custom.displayMode", "value": "color-background" }] },
          { "matcher": { "id": "byName", "options": "Severity"     }, "properties": [{ "id": "custom.width", "value": 100 }] },
          { "matcher": { "id": "byName", "options": "Agent"        }, "properties": [{ "id": "custom.width", "value": 100 }] },
          { "matcher": { "id": "byName", "options": "OCSF Class"   }, "properties": [{ "id": "custom.width", "value": 160 }] },
          { "matcher": { "id": "byName", "options": "Decoder"      }, "properties": [{ "id": "custom.width", "value": 160 }] },
          { "matcher": { "id": "byName", "options": "Fired Times"  }, "properties": [{ "id": "custom.width", "value": 90  }] },
          { "matcher": { "id": "byName", "options": "MITRE ID"     }, "properties": [{ "id": "custom.width", "value": 90  }] },
          { "matcher": { "id": "byName", "options": "Src IP"       }, "properties": [{ "id": "custom.width", "value": 120 }] }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
          "rawSql": "SELECT time AS \"Time\", device_name AS \"Agent\", finding_uid AS \"Rule ID\", finding_title AS \"Rule Description\", wazuh_rule_level AS \"Level\", severity AS \"Severity\", class_name AS \"OCSF Class\", activity_name AS \"Activity\", decoder_name AS \"Decoder\", finding_types AS \"Rule Groups\", wazuh_fired_times AS \"Fired Times\", actor_user AS \"User\", src_ip AS \"Src IP\", dst_ip AS \"Dst IP\", file_name AS \"File\", attack_id AS \"MITRE ID\", attack_technique AS \"Technique\", attack_tactic AS \"Tactic\", pci_dss AS \"PCI DSS\", gdpr AS \"GDPR\", hipaa AS \"HIPAA\", nist_800_53 AS \"NIST\" FROM merge('wazuh_ocsf', '^ocsf_.+$') WHERE $__timeFilter(time) AND device_name IN (${device_name:singlequote}) AND severity IN (${severity:singlequote}) AND class_name IN (${class_name:singlequote}) AND wazuh_rule_level >= ${min_level} ORDER BY time DESC LIMIT 500",
          "format": 1,
          "refId": "A"
        }
      ]
