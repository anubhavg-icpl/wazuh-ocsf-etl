    {
      "id": 220,
      "type": "barchart",
      "title": "OCSF Field Fill Rate (% non-empty)",
      "description": "Shows how many records have each key OCSF field populated \u2014 confirms transformation quality.",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "${DS_CLICKHOUSE}"
      },
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 24,
        "h": 10
      },
      "options": {
        "orientation": "horizontal",
        "barRadius": 0.05,
        "barWidth": 0.8,
        "stacking": "none",
        "showValue": "always",
        "fillOpacity": 75,
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "dark-red",
                "value": null
              },
              {
                "color": "orange",
                "value": 50
              },
              {
                "color": "yellow",
                "value": 75
              },
              {
                "color": "green",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "${DS_CLICKHOUSE}"
          },
          "rawSql": "SELECT field, fill_pct FROM (SELECT 'class_name' AS field,       round(100*countIf(class_name != '') / count(), 1) AS fill_pct FROM merge('wazuh_ocsf', '^ocsf_.+$') WHERE $__timeFilter(time) UNION ALL SELECT 'severity',                   round(100*countIf(severity != '') / count(), 1) FROM merge('wazuh_ocsf', '^ocsf_.+$') WHERE $__timeFilter(time) UNION ALL SELECT 'finding_uid',                round(100*countIf(finding_uid != '') / count(), 1) FROM merge('wazuh_ocsf', '^ocsf_.+$') WHERE $__timeFilter(time) UNION ALL SELECT 'finding_title',              round(100*countIf(finding_title != '') / count(), 1) FROM merge('wazuh_ocsf', '^ocsf_.+$') WHERE $__timeFilter(time) UNION ALL SELECT 'wazuh_rule_level',           round(100*countIf(wazuh_rule_level > 0) / count(), 1) FROM merge('wazuh_ocsf', '^ocsf_.+$') WHERE $__timeFilter(time) UNION ALL SELECT 'device_name',                round(100*countIf(device_name != '') / count(), 1) FROM merge('wazuh_ocsf', '^ocsf_.+$') WHERE $__timeFilter(time) UNION ALL SELECT 'manager_name',               round(100*countIf(manager_name != '') / count(), 1) FROM merge('wazuh_ocsf', '^ocsf_.+$') WHERE $__timeFilter(time) UNION ALL SELECT 'activity_name',              round(100*countIf(activity_name != '') / count(), 1) FROM merge('wazuh_ocsf', '^ocsf_.+$') WHERE $__timeFilter(time) UNION ALL SELECT 'decoder_name',               round(100*countIf(decoder_name != '') / count(), 1) FROM merge('wazuh_ocsf', '^ocsf_.+$') WHERE $__timeFilter(time) UNION ALL SELECT 'actor_user',                 round(100*countIf(actor_user != '') / count(), 1) FROM merge('wazuh_ocsf', '^ocsf_.+$') WHERE $__timeFilter(time) UNION ALL SELECT 'src_ip',                     round(100*countIf(src_ip != '') / count(), 1) FROM merge('wazuh_ocsf', '^ocsf_.+$') WHERE $__timeFilter(time) UNION ALL SELECT 'dst_ip',                     round(100*countIf(dst_ip != '') / count(), 1) FROM merge('wazuh_ocsf', '^ocsf_.+$') WHERE $__timeFilter(time) UNION ALL SELECT 'file_name',                  round(100*countIf(file_name != '') / count(), 1) FROM merge('wazuh_ocsf', '^ocsf_.+$') WHERE $__timeFilter(time) UNION ALL SELECT 'attack_id (MITRE)',          round(100*countIf(attack_id != '') / count(), 1) FROM merge('wazuh_ocsf', '^ocsf_.+$') WHERE $__timeFilter(time) UNION ALL SELECT 'attack_tactic',              round(100*countIf(attack_tactic != '') / count(), 1) FROM merge('wazuh_ocsf', '^ocsf_.+$') WHERE $__timeFilter(time) UNION ALL SELECT 'pci_dss',                    round(100*countIf(pci_dss != '') / count(), 1) FROM merge('wazuh_ocsf', '^ocsf_.+$') WHERE $__timeFilter(time) UNION ALL SELECT 'gdpr',                       round(100*countIf(gdpr != '') / count(), 1) FROM merge('wazuh_ocsf', '^ocsf_.+$') WHERE $__timeFilter(time) UNION ALL SELECT 'hipaa',                      round(100*countIf(hipaa != '') / count(), 1) FROM merge('wazuh_ocsf', '^ocsf_.+$') WHERE $__timeFilter(time) UNION ALL SELECT 'nist_800_53',                round(100*countIf(nist_800_53 != '') / count(), 1) FROM merge('wazuh_ocsf', '^ocsf_.+$') WHERE $__timeFilter(time) UNION ALL SELECT 'finding_types (rule groups)',round(100*countIf(finding_types != '') / count(), 1) FROM merge('wazuh_ocsf', '^ocsf_.+$') WHERE $__timeFilter(time)) ORDER BY fill_pct DESC",
          "format": 1,
          "refId": "A"
        }
      ]
    },
